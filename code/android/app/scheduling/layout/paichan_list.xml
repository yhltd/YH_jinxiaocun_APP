<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/WhiteSmoke"
    tools:context=".scheduling.activity.PaiChanListActivity">

    <!-- 搜索区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/shape_corner"
        android:layout_margin="10dp"
        android:padding="8dp">

        <EditText
            android:id="@+id/search_order_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入订单号"
            android:padding="12dp"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/search_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="搜索"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:background="@drawable/pcbtn_style"
            android:textColor="@color/white" />
    </LinearLayout>

    <!-- 整个表格区域（表头和内容一起滑动） -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="5dp"
        android:scrollbars="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/pcbeijing1"
            android:orientation="vertical">

            <!-- 表头（和内容一起滑动） -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/pcrow_header"
                android:padding="10dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="编号"
                    android:textColor="@color/title_text"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="订单号"
                    android:textColor="@color/title_text"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="生产数量"
                    android:textColor="@color/title_text"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="类型"
                    android:textColor="@color/title_text"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="是否插单"
                    android:textColor="@color/title_text"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="开始生产日期"
                    android:textColor="@color/title_text"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="预计结束时间"
                    android:textColor="@color/title_text"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>

            <!-- 列表内容区域 -->
            <ListView
                android:id="@+id/paichan_listview"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:dividerHeight="1dp"
                android:paddingBottom="5dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 新增按钮 -->
    <!-- 修改底部按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="15dp">

        <Button
            android:id="@+id/add_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="新增排产"
            android:paddingLeft="25dp"
            android:paddingRight="25dp"
            android:background="@drawable/pcbtn_style"
            android:textColor="@color/white" />

        <View
            android:layout_width="20dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/paichan_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="排产"
            android:paddingLeft="25dp"
            android:paddingRight="25dp"
            android:background="@drawable/pcbtn_style"
            android:textColor="@color/white" />

    </LinearLayout>

</LinearLayout>