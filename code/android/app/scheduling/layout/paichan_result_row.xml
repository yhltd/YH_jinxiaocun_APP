<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="55dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/pcrow_main"
    android:padding="8dp">

    <TextView
        android:id="@+id/dingdanhao"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:text="订单号"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/dingdanmingcheng"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="订单名称"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/kaishishijian"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="开始时间"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/jiezhishijian"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="结束时间"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/charu"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:text="是否插入"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/dingdanleixing"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="订单类型"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/gongxushuliang"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="工序数量"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/gongxumingcheng"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="工序名称"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/gongxuxiaolv"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="工序效率"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center" />

</LinearLayout>