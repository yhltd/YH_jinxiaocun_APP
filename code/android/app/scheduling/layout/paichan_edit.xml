<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pcbeijing1"
    tools:context=".scheduling.activity.PaiChanEditActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/pcchange_card"
            android:padding="15dp">

            <!-- 订单号 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="订单号"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="10dp" />

            <Spinner
                android:id="@+id/order_spinner"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/form_input" />

            <!-- 可生产数量 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="可生产数量"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="15dp" />

            <TextView
                android:id="@+id/available_num"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/form_input"
                android:gravity="center_vertical"
                android:paddingLeft="10dp"
                android:textColor="@color/black" />

            <!-- 生产数量 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="生产数量"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="15dp" />

            <EditText
                android:id="@+id/production_num"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/form_input"
                android:hint="请输入生产数量"
                android:inputType="number"
                android:paddingLeft="10dp"
                android:textColor="@color/black" />

            <!-- 类型 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="类型"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="15dp" />

            <Spinner
                android:id="@+id/type_spinner"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/form_input" />

            <!-- 是否插单 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="是否插单"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="15dp" />

            <Spinner
                android:id="@+id/is_insert_spinner"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/form_input" />

            <!-- 开始生产日期 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开始生产日期"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="15dp" />

            <EditText
                android:id="@+id/start_date"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/form_input"
                android:hint="请选择开始生产日期"
                android:paddingLeft="10dp"
                android:textColor="@color/black" />

            <!-- 预计结束时间 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="预计结束时间"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="15dp" />

            <EditText
                android:id="@+id/end_date"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/form_input"
                android:hint="请选择预计结束时间"
                android:paddingLeft="10dp"
                android:textColor="@color/black" />

            <!-- 操作按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="30dp">

                <Button
                    android:id="@+id/save_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="保存"
                    android:paddingLeft="25dp"
                    android:paddingRight="25dp"
                    android:background="@drawable/pcbtn_style"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="20dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/cancel_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="取消"
                    android:paddingLeft="25dp"
                    android:paddingRight="25dp"
                    android:background="@drawable/pcbtn_style"
                    android:textColor="@color/white" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>